BEGIN Configuration File: mesh6x7_coherence
// Cache-coherence-style traffic on the 6x7 (42-node) mesh.
// BookSim has no coherence protocol FSM; this models the *traffic*:
// request/reply transactions, control vs data packet sizes, read/write
// mix, and separate request/response subnets (deadlock avoidance).

topology     = anynet;
network_file = mesh6x7_anynet;
routing_function = min;

// --- Coherence transaction traffic: request/reply ---
use_read_write = 1;
write_fraction = 0.3;        // read-heavy load

// 16B/flit assumption: control = 1 flit, 64B cache line = 4 data + 1 head = 5 flits
read_request_size  = 1;      // read request = address control packet
read_reply_size    = 5;      // read reply   = one cache line
write_request_size = 5;      // write request carries data
write_reply_size   = 1;      // write reply  = ack

// --- Two subnets isolate requests from replies (protocol deadlock avoidance) ---
subnets = 2;
read_request_subnet  = 0;
write_request_subnet = 0;
read_reply_subnet    = 1;
write_reply_subnet   = 1;

// In read_write mode the routing function partitions VCs per message type.
// Default ranges assume 16 VCs; since the subnets already separate requests
// from replies physically, let every type use the full VC range of its subnet.
read_request_begin_vc  = 0;
read_request_end_vc    = 3;
write_request_begin_vc = 0;
write_request_end_vc   = 3;
read_reply_begin_vc    = 0;
read_reply_end_vc      = 3;
write_reply_begin_vc   = 0;
write_reply_end_vc     = 3;

num_vcs     = 4;
vc_buf_size = 8;
vc_allocator = islip;
sw_allocator = islip;
alloc_iters  = 1;

sim_type       = latency;
traffic        = uniform;    // distributed directory; use hotspot for centralized
packet_size    = 1;          // overridden by the *_size params in read_write mode
sample_period  = 1000;
warmup_periods = 3;
sim_count      = 1;
injection_rate = 0.05;

END Configuration File: mesh6x7_coherence
